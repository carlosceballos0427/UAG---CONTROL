# ============================================================================
# .gitignore — App Seguimiento (UAG Control)
# Stack: Vite + React + Tailwind CSS + Firebase Data Connect + Auth
# Last updated: 2026-02-27
# ============================================================================

# ──────────────────────────────────────────────────────────
# 🔐 SECURITY — Secrets, credentials, and sensitive data
# ──────────────────────────────────────────────────────────

# Environment variables (may contain API keys, DB passwords, secrets)
.env
.env.*
!.env.example

# Firebase service account keys (CRITICAL — never commit these)
*-service-account*.json
service-account*.json
serviceAccountKey*.json
*-firebase-adminsdk-*.json
firebase-adminsdk*.json
*-credentials*.json

# Google Cloud credentials
gcloud-*.json
application_default_credentials.json

# Private keys and certificates
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der

# SSH keys
id_rsa
id_ed25519
*.pub

# ──────────────────────────────────────────────────────────
# 📦 Dependencies
# ──────────────────────────────────────────────────────────

node_modules/
jspm_packages/
.pnp.*
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ──────────────────────────────────────────────────────────
# 🏗️ Build output
# ──────────────────────────────────────────────────────────

dist/
build/
out/
*.local

# ──────────────────────────────────────────────────────────
# ⚡ Vite
# ──────────────────────────────────────────────────────────

# Vite cache and temp files
.vite/
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# ──────────────────────────────────────────────────────────
# 🔥 Firebase
# ──────────────────────────────────────────────────────────

# Firebase debug and cache logs
firebase-debug.log
firebase-debug.*.log
firestore-debug.log
ui-debug.log
pubsub-debug.log
database-debug.log

# Firebase local emulator data (may contain sensitive test data)
dataconnect/.dataconnect/
.firebase/
firestore_export/

# Firebase hosting cache
.cache/

# ──────────────────────────────────────────────────────────
# 📊 Data files — Sensitive / business data
# ──────────────────────────────────────────────────────────

# Excel files (may contain personal/financial data from UAG contracts)
*.xlsx
*.xls
*.csv
*.tsv

# Database dumps and backups
*.sql
*.sqlite
*.sqlite3
*.db
*.dump
*.bak

# ──────────────────────────────────────────────────────────
# 📝 Logs
# ──────────────────────────────────────────────────────────

logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
error.log

# Node.js diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ──────────────────────────────────────────────────────────
# 🧪 Testing & Coverage
# ──────────────────────────────────────────────────────────

coverage/
*.lcov
.nyc_output/

# ──────────────────────────────────────────────────────────
# 🐍 Python (for helper scripts like get_headers.py)
# ──────────────────────────────────────────────────────────

__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt

